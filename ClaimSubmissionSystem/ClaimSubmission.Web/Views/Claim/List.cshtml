@model ClaimSubmission.Web.Models.ClaimsPaginatedListViewModel

@{
    ViewData["Title"] = "Claims Management";
    var claimsCount = Model?.Claims?.Count ?? 0;
    var pendingCount = Model?.Claims?.Count(c => c.ClaimStatus == "Pending") ?? 0;
    var approvedCount = Model?.Claims?.Count(c => c.ClaimStatus == "Approved") ?? 0;
}

<div id="main-content" class="pt-4">
    <!-- Page Header with Actions -->
    <div class="d-flex justify-content-between align-items-center mb-8">
        <div>
            <h1 class="mb-2">Claims Management</h1>
            <p class="text-muted">Manage and track all your healthcare claims</p>
        </div>
        <div class="d-flex gap-3">
            <a href="@Url.Action("Add", "Claim")" class="btn btn-success btn-lg">
                <i class="bi bi-plus-circle"></i> Submit New Claim
            </a>
        </div>
    </div>

    <!-- Quick Stats -->
    <div class="row mb-8">
        <div class="col-md-3 mb-4">
            <div class="card">
                <div class="card-body text-center">
                    <div class="stat-value text-primary">@claimsCount</div>
                    <div class="stat-label">Total Claims</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-4">
            <div class="card">
                <div class="card-body text-center">
                    <div class="stat-value text-warning">@pendingCount</div>
                    <div class="stat-label">Pending Review</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-4">
            <div class="card">
                <div class="card-body text-center">
                    <div class="stat-value text-success">@approvedCount</div>
                    <div class="stat-label">Approved</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-4">
            <div class="card">
                <div class="card-body text-center">
                    <div class="stat-value text-info">$0.00</div>
                    <div class="stat-label">Total Value</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Alerts -->
    @if (!string.IsNullOrEmpty(ViewBag.Error))
    {
        <div class="alert alert-danger alert-dismissible fade show animate-slide-in" role="alert">
            <div class="d-flex gap-3">
                <span>⚠️</span>
                <div style="flex: 1;">@ViewBag.Error</div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(TempData["Message"]?.ToString()))
    {
        <div class="alert alert-success alert-dismissible fade show animate-slide-in" role="alert">
            <div class="d-flex gap-3">
                <span>✅</span>
                <div style="flex: 1;">@TempData["Message"]</div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    }

    <!-- Claims Table -->
    <div class="card">
        <div class="card-header">
            <h5 class="card-title mb-0">
                <i class="bi bi-table"></i> Your Claims
            </h5>
        </div>
        <div class="card-body p-0">
            @if (Model != null && Model.Claims != null && Model.Claims.Count > 0)
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th style="width: 15%;">Claim #</th>
                                <th style="width: 20%;">Patient Name</th>
                                <th style="width: 20%;">Provider</th>
                                <th style="width: 15%;">Date of Service</th>
                                <th style="width: 12%;">Amount</th>
                                <th style="width: 12%;">Status</th>
                                <th style="width: 15%; text-align: right;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var claim in Model.Claims)
                            {
                                <tr class="align-middle">
                                    <td>
                                        <span class="badge badge-primary">@claim.ClaimNumber</span>
                                    </td>
                                    <td>@claim.PatientName</td>
                                    <td>@claim.ProviderName</td>
                                    <td>@claim.DateOfService.ToString("MM/dd/yyyy")</td>
                                    <td class="fw-semibold">$@claim.ClaimAmount.ToString("0.00")</td>
                                    <td>
                                        @switch (claim.ClaimStatus)
                                        {
                                            case "Approved":
                                                <span class="badge badge-success"><i class="bi bi-check-circle"></i> Approved</span>
                                                break;
                                            case "Pending":
                                                <span class="badge badge-warning"><i class="bi bi-hourglass-split"></i> Pending</span>
                                                break;
                                            case "Rejected":
                                                <span class="badge badge-danger"><i class="bi bi-x-circle"></i> Rejected</span>
                                                break;
                                            default:
                                                <span class="badge badge-info"><i class="bi bi-info-circle"></i> @claim.ClaimStatus</span>
                                                break;
                                        }
                                    </td>
                                    <td style="text-align: right;">
                                        <div class="d-flex gap-2 justify-content-end">
                                            <a href="@Url.Action("Edit", "Claim", new { id = claim.ClaimId })" 
                                               class="btn btn-sm btn-outline-primary" title="Edit claim">
                                                <i class="bi bi-pencil-square"></i> Edit
                                            </a>
                                            <form method="post" action="@Url.Action("Delete", "Claim", new { id = claim.ClaimId })" 
                                                  style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this claim?');">
                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete claim">
                                                    <i class="bi bi-trash"></i> Delete
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-state-icon">📋</div>
                    <h3 class="empty-state-title">No Claims Found</h3>
                    <p class="empty-state-text">You haven't submitted any claims yet. Start by creating a new claim.</p>
                    <div class="empty-state-action">
                        <a href="@Url.Action("Add", "Claim")" class="btn btn-primary btn-lg">
                            <i class="bi bi-plus-circle"></i> Submit Your First Claim
                        </a>
                    </div>
                </div>
            }
        </div>
        @if (Model?.TotalPages > 1)
        {
            <div class="card-footer">
                <nav aria-label="Claims pagination">
                    <ul class="pagination justify-content-center mb-0">
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                <a class="page-link" href="@Url.Action("List", "Claim", new { page = i })">
                                    @i
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

<style>
    .table-responsive::-webkit-scrollbar {
        height: 8px;
    }
    
    .table-responsive::-webkit-scrollbar-track {
        background: var(--color-bg-light);
    }
    
    .table-responsive::-webkit-scrollbar-thumb {
        background: var(--color-border);
        border-radius: 4px;
    }
    
    .table-responsive::-webkit-scrollbar-thumb:hover {
        background: var(--color-primary);
    }
</style>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            No claims found. <a href="@Url.Action("Add", "Claim")">Create a new claim</a>
        </div>
    }
</div>
