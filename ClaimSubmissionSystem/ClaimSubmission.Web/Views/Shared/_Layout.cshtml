<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Professional Healthcare Claim Submission System" />
    <meta name="theme-color" content="#3b82f6" />
    <title>@ViewData["Title"] - Claim Submission System</title>
    <script type="importmap"></script>
    
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    
    <!-- Design System & Components -->
    <link rel="stylesheet" href="~/css/design-system.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    
    <!-- Dark Theme & Custom Styles -->
    <link rel="stylesheet" href="~/css/dark-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ClaimSubmission.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <!-- Skip to Main Content Link for Accessibility -->
    <a href="#main-content" class="skip-to-main">Skip to main content</a>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark" role="navigation" aria-label="Main navigation">
            <div class="container-fluid">
                <!-- Logo & Brand -->
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index" title="Go to dashboard">
                    <i class="bi bi-shield-check" style="margin-right: 0.5rem;"></i>
                    <span>ClaimSystem</span>
                </a>
                
                <!-- Mobile Toggle Button -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" 
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <!-- Navigation Menu -->
                <div class="navbar-collapse collapse d-lg-flex justify-content-between">
                    <ul class="navbar-nav mx-auto flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")" 
                               asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door"></i>
                                <span>Dashboard</span>
                            </a>
                        </li>
                        
                        @if (Context.Session.GetString("IsAuthenticated") == "true")
                        {
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Claim" ? "active" : "")" 
                                   asp-area="" asp-controller="Claim" asp-action="List">
                                    <i class="bi bi-file-earmark"></i>
                                    <span>Claims</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Claim" asp-action="Add">
                                    <i class="bi bi-plus-circle"></i>
                                    <span>New Claim</span>
                                </a>
                            </li>
                        }
                    </ul>
                    
                    <!-- Right Side Menu -->
                    <ul class="navbar-nav">
                        @if (Context.Session.GetString("IsAuthenticated") == "true")
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="userMenu" role="button" 
                                   data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-circle"></i>
                                    <span>@(Context.Session.GetString("FullName") ?? "User")</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenu">
                                    <li><a class="dropdown-item" href="#">My Profile</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item text-danger" asp-area="" asp-controller="Authentication" asp-action="Logout">
                                            <i class="bi bi-box-arrow-right"></i> Logout
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Authentication" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right"></i>
                                    <span>Login</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Authentication" asp-action="Register">
                                    <i class="bi bi-person-plus"></i>
                                    <span>Register</span>
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    
    <main role="main" class="flex-grow-1">
        <div class="container-fluid">
            @RenderBody()
        </div>
    </main>

    <footer class="mt-12 pt-8 border-top" style="border-top-color: var(--color-border);">
        <div class="container-fluid">
            <div class="row mb-8">
                <div class="col-md-3 mb-4">
                    <h6 class="text-primary mb-3">Claim Submission System</h6>
                    <p class="small text-muted">Secure, professional healthcare claims management platform.</p>
                </div>
                <div class="col-md-3 mb-4">
                    <h6 class="text-primary mb-3">Quick Links</h6>
                    <ul class="list-unstyled small">
                        <li><a href="@Url.Action("Index", "Home")" class="text-muted text-decoration-none">Dashboard</a></li>
                        <li><a href="@Url.Action("List", "Claim")" class="text-muted text-decoration-none">Claims</a></li>
                        <li><a href="#" class="text-muted text-decoration-none">Support</a></li>
                    </ul>
                </div>
                <div class="col-md-3 mb-4">
                    <h6 class="text-primary mb-3">Legal</h6>
                    <ul class="list-unstyled small">
                        <li><a href="@Url.Action("Privacy", "Home")" class="text-muted text-decoration-none">Privacy Policy</a></li>
                        <li><a href="#" class="text-muted text-decoration-none">Terms of Service</a></li>
                        <li><a href="#" class="text-muted text-decoration-none">Compliance</a></li>
                    </ul>
                </div>
                <div class="col-md-3 mb-4">
                    <h6 class="text-primary mb-3">Contact</h6>
                    <p class="small text-muted mb-1">📧 support@claims.local</p>
                    <p class="small text-muted mb-0">📱 1-800-CLAIMS</p>
                </div>
            </div>
            <div style="border-top: 1px solid var(--color-border); padding-top: var(--spacing-6);">
                <div class="d-flex justify-content-between align-items-center flex-wrap">
                    <p class="small text-muted mb-0">© 2026 Claim Submission System. All rights reserved.</p>
                    <p class="small text-muted mb-0">HIPAA Compliant • Secure & Encrypted</p>
                </div>
            </div>
        </div>
    </footer>
    <!-- JavaScript Libraries -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Application Scripts -->
    <script src="~/js/auth-storage.js" asp-append-version="true"></script>
    <script src="~/js/auth-interceptor.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/ui-animations.js" asp-append-version="true"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
