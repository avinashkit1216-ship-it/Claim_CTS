@model ClaimSubmission.Web.Models.LoginViewModel

@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Claim Submission System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        html, body {
            height: 100%;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }

        body {
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .login-container {
            width: 100%;
            max-width: 400px;
            padding: 20px;
        }

        .login-card {
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
            border: none;
            border-radius: 10px;
        }

        .login-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 30px;
            text-align: center;
            border-radius: 10px 10px 0 0;
        }

        .login-header h1 {
            font-size: 24px;
            font-weight: 600;
            margin: 0 0 5px 0;
        }

        .login-header p {
            font-size: 14px;
            margin: 0;
            opacity: 0.9;
        }

        .login-body {
            padding: 30px;
        }

        .form-control {
            border-radius: 5px;
            padding: 12px 15px;
            font-size: 14px;
            border: 1px solid #ddd;
        }

        .form-control:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
        }

        .btn-login {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            padding: 12px;
            font-size: 16px;
            font-weight: 600;
            border-radius: 5px;
        }

        .btn-login:hover {
            background: linear-gradient(135deg, #5568d3 0%, #6a3f96 100%);
            color: white;
        }

        .alert {
            border-radius: 5px;
            margin-bottom: 20px;
        }

        .form-check-input {
            margin-top: 5px;
        }

        .footer-text {
            text-align: center;
            margin-top: 20px;
            color: #666;
            font-size: 13px;
        }

        .error-text {
            color: #dc3545;
            font-size: 13px;
            margin-top: 5px;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="card login-card">
            <div class="login-header">
                <h1>Claim Submission System</h1>
                <p>Secure Portal</p>
            </div>
            <div class="login-body">
                @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <strong>Login Failed!</strong>
                        @Html.ValidationSummary(false)
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form method="post" asp-action="Login" asp-controller="Authentication">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="Username" class="form-label fw-500">Username</label>
                        <input asp-for="Username" class="form-control @(ViewData.ModelState.ContainsKey(nameof(LoginViewModel.Username)) && ViewData.ModelState[nameof(LoginViewModel.Username)]?.Errors.Count > 0 ? "is-invalid" : "")" 
                               placeholder="Enter your username" required autofocus />
                        <span asp-validation-for="Username" class="error-text"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-500">Password</label>
                        <input asp-for="Password" type="password" class="form-control @(ViewData.ModelState.ContainsKey(nameof(LoginViewModel.Password)) && ViewData.ModelState[nameof(LoginViewModel.Password)]?.Errors.Count > 0 ? "is-invalid" : "")" 
                               placeholder="Enter your password" required />
                        <span asp-validation-for="Password" class="error-text"></span>
                    </div>

                    <div class="mb-3 form-check">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label">Remember me</label>
                    </div>

                    <button type="submit" class="btn btn-login w-100 text-white">Sign In</button>
                </form>

                <hr />

                <div class="footer-text">
                    <p>© 2024 Claim Submission System<br/>All rights reserved</p>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

