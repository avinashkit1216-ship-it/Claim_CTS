@model ClaimSubmission.Web.Models.LoginViewModel

@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Secure login for Claim Submission System" />
    <meta name="theme-color" content="#3b82f6" />
    <title>@ViewData["Title"] - Claim Submission System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/design-system.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dark-theme.css" asp-append-version="true" />
    <style>
        html, body {
            height: 100%;
            background: linear-gradient(135deg, var(--color-bg-dark) 0%, var(--color-bg-darker) 50%, var(--color-bg-lighter) 100%);
            font-family: var(--font-family-base);
            min-height: 100vh;
        }

        body {
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }

        /* Animated background elements */
        body::before {
            content: '';
            position: absolute;
            width: 400px;
            height: 400px;
            top: -10%;
            right: -5%;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.15) 0%, transparent 70%);
            border-radius: 50%;
            animation: float 20s ease-in-out infinite;
            z-index: 0;
        }

        body::after {
            content: '';
            position: absolute;
            width: 350px;
            height: 350px;
            bottom: -10%;
            left: -5%;
            background: radial-gradient(circle, rgba(20, 184, 166, 0.15) 0%, transparent 70%);
            border-radius: 50%;
            animation: float 25s ease-in-out infinite reverse;
            z-index: 0;
        }

        @@keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(30px); }
        }

        .login-wrapper {
            position: relative;
            z-index: 10;
            width: 100%;
            max-width: 440px;
            padding: var(--spacing-4);
            animation: slideIn 0.5s ease-out;
        }

        .login-card {
            background-color: rgba(26, 32, 44, 0.95);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(59, 130, 246, 0.2);
            border-radius: var(--radius-2xl);
            overflow: hidden;
            box-shadow: var(--shadow-2xl);
            transition: var(--transition-base);
        }

        .login-card:hover {
            box-shadow: var(--shadow-2xl), 0 0 30px rgba(59, 130, 246, 0.2);
            border-color: rgba(59, 130, 246, 0.4);
        }

        .login-header {
            background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
            padding: var(--spacing-10) var(--spacing-6);
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .login-header::before {
            content: '';
            position: absolute;
            inset: 0;
            background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        }

        .login-header-content {
            position: relative;
            z-index: 1;
        }

        .login-header h1 {
            font-size: var(--font-size-3xl);
            font-weight: var(--font-weight-bold);
            margin: 0 0 var(--spacing-2) 0;
            color: white;
            text-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: var(--spacing-2);
        }

        .login-header h1 i {
            font-size: var(--font-size-3xl);
        }

        .login-header p {
            font-size: var(--font-size-base);
            margin: 0;
            color: rgba(255, 255, 255, 0.9);
            font-weight: var(--font-weight-medium);
        }

        .login-body {
            padding: var(--spacing-8) var(--spacing-6);
        }

        .form-label {
            color: var(--color-text-primary);
            font-weight: var(--font-weight-semibold);
            font-size: var(--font-size-sm);
            margin-bottom: var(--spacing-2);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .form-control {
            background-color: rgba(45, 55, 72, 0.5);
            border: 2px solid rgba(59, 130, 246, 0.2);
            color: var(--color-text-primary);
            padding: var(--spacing-3) var(--spacing-4);
            font-size: var(--font-size-base);
            border-radius: var(--radius-lg);
            transition: var(--transition-base);
        }

        .form-control::placeholder {
            color: var(--color-text-disabled);
        }

        .form-control:focus {
            background-color: rgba(45, 55, 72, 0.8);
            border-color: var(--color-primary);
            color: var(--color-text-primary);
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1), var(--shadow-md);
            outline: none;
        }

        .form-check-input {
            width: 20px;
            height: 20px;
            margin-top: 2px;
            background-color: rgba(45, 55, 72, 0.5);
            border: 2px solid rgba(59, 130, 246, 0.3);
            border-radius: var(--radius-sm);
            accent-color: var(--color-primary);
            cursor: pointer;
        }

        .form-check-input:checked {
            background-color: var(--color-primary);
            border-color: var(--color-primary);
        }

        .form-check-label {
            color: var(--color-text-secondary);
            margin-left: var(--spacing-2);
            font-weight: var(--font-weight-regular);
            cursor: pointer;
        }

        .btn-login {
            background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
            border: none;
            color: white;
            padding: var(--spacing-3) var(--spacing-6);
            font-size: var(--font-size-base);
            font-weight: var(--font-weight-bold);
            border-radius: var(--radius-lg);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            transition: var(--transition-base);
            box-shadow: var(--shadow-lg), 0 0 15px rgba(59, 130, 246, 0.3);
            cursor: pointer;
            position: relative;
            overflow: hidden;
            width: 100%;
        }

        .btn-login::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
            transform: translateX(-100%);
            transition: transform 0.6s ease;
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-xl), 0 0 25px rgba(59, 130, 246, 0.4);
        }

        .btn-login:hover::before {
            transform: translateX(100%);
        }

        .btn-login:active {
            transform: translateY(0);
        }

        .btn-login:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .error-alert {
            background-color: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.3);
            border-radius: var(--radius-lg);
            padding: var(--spacing-4);
            margin-bottom: var(--spacing-4);
            color: var(--color-danger-light);
        }

        .error-alert strong {
            display: flex;
            align-items: center;
            gap: var(--spacing-2);
            margin-bottom: var(--spacing-2);
        }

        .error-text {
            color: var(--color-danger-light);
            font-size: var(--font-size-sm);
            margin-top: var(--spacing-1);
            display: block;
            font-weight: var(--font-weight-medium);
        }

        .divider {
            background: linear-gradient(90deg, transparent, var(--color-border), transparent);
            height: 1px;
            margin: var(--spacing-6) 0;
        }

        .footer-text {
            text-align: center;
            margin-top: var(--spacing-4);
            color: var(--color-text-tertiary);
            font-size: var(--font-size-sm);
            line-height: var(--line-height-relaxed);
        }

        .footer-text a {
            color: var(--color-primary-light);
            font-weight: var(--font-weight-medium);
            text-decoration: none;
            transition: var(--transition-fast);
        }

        .footer-text a:hover {
            color: var(--color-secondary-light);
            text-decoration: underline;
        }

        .signup-link {
            text-align: center;
            margin-top: var(--spacing-4);
            color: var(--color-text-tertiary);
            font-size: var(--font-size-sm);
        }

        .signup-link a {
            color: var(--color-primary-light);
            font-weight: var(--font-weight-semibold);
            text-decoration: none;
            transition: var(--transition-fast);
        }

        .signup-link a:hover {
            color: var(--color-secondary-light);
            text-decoration: underline;
        }

        /* Responsive */
        @@media (max-width: 576px) {
            .login-wrapper {
                padding: var(--spacing-2);
            }

            .login-card {
                border-radius: var(--radius-xl);
            }

            .login-header {
                padding: var(--spacing-6) var(--spacing-4);
            }

            .login-header h1 {
                font-size: var(--font-size-2xl);
            }

            .login-body {
                padding: var(--spacing-6) var(--spacing-4);
            }
        }
    </style>
            right: 0;
            bottom: 0;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
        }

        .login-header h1 {
            font-size: 28px;
            font-weight: 700;
            margin: 0 0 8px 0;
            color: white;
            text-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
            position: relative;
            z-index: 1;
        }

        .login-header p {
            font-size: 14px;
            margin: 0;
            color: rgba(255, 255, 255, 0.9);
            font-weight: 500;
            position: relative;
            z-index: 1;
        }

        .login-body {
            padding: 40px 30px;
            background-color: #0f172a;
        }

        .form-control,
        .form-select {
            background-color: rgba(45, 55, 72, 0.6);
            border: 2px solid rgba(59, 130, 246, 0.2);
            color: #f1f5f9;
            padding: 12px 16px;
            font-size: 15px;
            border-radius: 8px;
            transition: all 0.3s ease;
        }

        .form-control::placeholder {
            color: #94a3b8;
        }

        .form-control:focus,
        .form-select:focus {
            background-color: rgba(45, 55, 72, 0.8);
            border-color: #3b82f6;
            color: #f1f5f9;
            box-shadow: 0 0 0 0.25rem rgba(59, 130, 246, 0.25);
        }

        .form-label {
            color: #3b82f6;
            font-weight: 600;
            font-size: 14px;
            margin-bottom: 0.5rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .form-check-input {
            width: 20px;
            height: 20px;
            margin-top: 3px;
            accent-color: #3b82f6;
        }

        .form-check-label {
            color: #cbd5e1;
            margin-left: 0.5rem;
            font-weight: 500;
        }

        .btn-login {
            background: linear-gradient(135deg, #3b82f6 0%, #14b8a6 100%);
            border: none;
            color: white;
            padding: 12px;
            font-size: 16px;
            font-weight: 700;
            border-radius: 8px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(59, 130, 246, 0.3);
            cursor: pointer;
            position: relative;
            overflow: hidden;
        }

        .btn-login::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            border-radius: 50%;
            background-color: rgba(255, 255, 255, 0.2);
            transform: translate(-50%, -50%);
            transition: width 0.6s, height 0.6s;
        }

        .btn-login:hover::before {
            width: 300px;
            height: 300px;
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(59, 130, 246, 0.4);
        }

        .btn-login:active {
            transform: translateY(0);
        }

        .alert {
            border-radius: 8px;
            margin-bottom: 20px;
            border: 1px solid;
            font-weight: 500;
        }

        .alert-danger {
            background-color: rgba(239, 68, 68, 0.1);
            color: #fecaca;
            border-color: rgba(239, 68, 68, 0.3);
        }

        .error-text {
            color: #fca5a5;
            font-size: 13px;
            margin-top: 5px;
            display: block;
            font-weight: 500;
        }

        .divider {
            background: linear-gradient(90deg, transparent, #334155, transparent);
            height: 1px;
            margin: 25px 0;
        }

        .footer-text {
            text-align: center;
            margin-top: 20px;
            color: #94a3b8;
            font-size: 13px;
            line-height: 1.6;
        }

        .footer-text a {
            color: #3b82f6;
            font-weight: 600;
            text-decoration: none;
            transition: color 0.2s ease;
        }

        .footer-text a:hover {
            color: #14b8a6;
            text-decoration: underline;
        }

        /* Responsive Design */
        @@media (max-width: 576px) {
            .login-header {
                padding: 30px 20px;
            }

            .login-header h1 {
                font-size: 24px;
            }

            .login-body {
                padding: 30px 20px;
            }

            .login-wrapper {
                padding: 10px;
            }

            
        }
        .reg-nav {
                text-align: center;
                margin-top: 15px;
                color : #94a3b8;
                font-size: 13px;
                line-height: 1.6;
            }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <div class="login-card">
            <!-- Header -->
            <div class="login-header">
                <div class="login-header-content">
                    <h1>
                        <i class="bi bi-shield-check"></i>
                        ClaimSystem
                    </h1>
                    <p>Secure Healthcare Claims Management</p>
                </div>
            </div>

            <!-- Body -->
            <div class="login-body">
                <!-- Error Alert -->
                @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                {
                    <div class="error-alert animate-slide-in" role="alert">
                        <strong>
                            <span>⚠️</span>
                            Login Failed
                        </strong>
                        @Html.ValidationSummary(false, "", new { style = "margin: 0; font-size: 14px;" }, "div")
                    </div>
                }

                <!-- Login Form -->
                <form method="post" asp-action="Login" asp-controller="Authentication">
                    @Html.AntiForgeryToken()

                    <!-- Username Field -->
                    <div class="mb-4">
                        <label asp-for="Username" class="form-label">Username or Email</label>
                        <input asp-for="Username"
                               class="form-control @(ViewData.ModelState.ContainsKey(nameof(LoginViewModel.Username)) && ViewData.ModelState[nameof(LoginViewModel.Username)]?.Errors.Count > 0 ? "is-invalid" : "")"
                               placeholder="Enter your username"
                               required
                               autofocus
                               autocomplete="username" />
                        <span asp-validation-for="Username" class="error-text"></span>
                    </div>

                    <!-- Password Field -->
                    <div class="mb-4">
                        <label asp-for="Password" class="form-label">Password</label>
                        <input asp-for="Password"
                               type="password"
                               class="form-control @(ViewData.ModelState.ContainsKey(nameof(LoginViewModel.Password)) && ViewData.ModelState[nameof(LoginViewModel.Password)]?.Errors.Count > 0 ? "is-invalid" : "")"
                               placeholder="Enter your password"
                               required
                               autocomplete="current-password" />
                        <span asp-validation-for="Password" class="error-text"></span>
                    </div>

                    <!-- Remember Me -->
                    <div class="mb-5 form-check">
                        <input asp-for="RememberMe" class="form-check-input" id="rememberMe" />
                        <label asp-for="RememberMe" class="form-check-label" for="rememberMe">Keep me logged in</label>
                    </div>

                    <!-- Submit Button -->
                    <button type="submit" class="btn-login" id="loginBtn">
                        <span>Sign In</span>
                    </button>
                </form>

                <!-- Divider -->
                <div class="divider"></div>

                <!-- Sign Up Link -->
                <div class="signup-link">
                    Don't have an account?
                    <a href="@Url.Action("Register", "Authentication")">Create one now</a>
                </div>

                <!-- Footer -->
                <div class="footer-text">
                    <p style="margin: 0; margin-top: var(--spacing-6);">
                        © 2026 Claim Submission System<br />
                        HIPAA Compliant • Secure & Encrypted
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/auth-storage.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const form = document.querySelector('form');
            const loginBtn = document.getElementById('loginBtn');
            
            if (form) {
                // Store username for next visit
                form.addEventListener('submit', function (e) {
                    const username = document.querySelector('input[name="Username"]')?.value;
                    if (username) {
                        sessionStorage.setItem('lastUsername', username);
                    }
                    loginBtn.disabled = true;
                    loginBtn.innerHTML = '<span class="spinner spinner-sm me-2"></span><span>Signing in...</span>';
                });
            }

            // Restore last username if available
            const lastUsername = sessionStorage.getItem('lastUsername');
            if (lastUsername) {
                const usernameInput = document.querySelector('input[name="Username"]');
                if (usernameInput) {
                    usernameInput.value = lastUsername;
                }
            }

            // Check if user is already authenticated
            if (authStorage && authStorage.isAuthenticated()) {
                console.log('User already authenticated, redirecting...');
                window.location.href = '/Home/Index';
            }
        });
    </script>
</body>
</html>

