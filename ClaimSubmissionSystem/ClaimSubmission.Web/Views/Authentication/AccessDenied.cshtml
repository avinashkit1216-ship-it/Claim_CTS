@{
    ViewData["Title"] = "Access Denied";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="alert alert-danger" role="alert">
                <h4 class="alert-heading">
                    <i class="bi bi-exclamation-triangle"></i> Access Denied
                </h4>
                <p class="mb-0">
                    You do not have permission to access this resource. If you believe this is an error, please contact an administrator.
                </p>
            </div>
            <div class="mt-4">
                <a href="@Url.Action("Index", "Home")" class="btn btn-primary">
                    <i class="bi bi-house-door"></i> Go to Dashboard
                </a>
                <a href="@Url.Action("Login", "Authentication")" class="btn btn-secondary">
                    <i class="bi bi-box-arrow-in-right"></i> Login
                </a>
            </div>
        </div>
    </div>
</div>
