@model dynamic

@{
    var label = ViewData["Label"] as string ?? "Label";
    var placeholder = ViewData["Placeholder"] as string ?? "";
    var icon = ViewData["Icon"] as string ?? "bi-tag";
    var required = ViewData["Required"] != null && (bool)ViewData["Required"];
    var helpText = ViewData["HelpText"] as string ?? "";
    var inputType = ViewData["InputType"] as string ?? "text";
    var rows = ViewData["Rows"] != null ? (int)ViewData["Rows"] : 1;
}

<div class="mb-4">
    <label class="form-label fw-bold">
        <i class="bi @icon me-1"></i>@label @(required ? "*" : "")
    </label>
    @if (rows > 1)
    {
        <textarea class="form-control" rows="@rows" placeholder="@placeholder" required="@required"></textarea>
    }
    else
    {
        <input type="@inputType" class="form-control" placeholder="@placeholder" required="@required" />
    }
    @if (!string.IsNullOrEmpty(helpText))
    {
        <div class="form-text">@helpText</div>
    }
</div>