@{
    ViewData["Title"] = "Home";
}

<section class="hero-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h1 class="display-4 fw-bold mb-4 animate-fade-in">Welcome to TaskFlow</h1>
                <p class="lead mb-4 animate-fade-in">
                    Streamline your productivity with our modern task management system.
                    Built with Clean Architecture for scalability and maintainability.
                </p>
                <div class="animate-fade-in">
                    <a href="/Task" class="btn btn-light btn-lg me-3">
                        <i class="bi bi-arrow-right-circle me-2"></i>Get Started
                    </a>
                    <a href="#features" class="btn btn-outline-light btn-lg">
                        <i class="bi bi-info-circle me-2"></i>Learn More
                    </a>
                </div>
            </div>
            <div class="col-lg-6 text-center">
                <i class="bi bi-check2-square display-1 text-white animate-fade-in"></i>
            </div>
        </div>
    </div>
</section>

<section id="features" class="py-5">
    <div class="container">
        <div class="row text-center mb-5">
            <div class="col-12">
                <h2 class="display-5 fw-bold">Why Choose TaskFlow?</h2>
                <p class="lead text-muted">Experience the power of modern software architecture</p>
            </div>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 text-center">
                    <div class="card-body">
                        <i class="bi bi-diagram-3 display-4 text-primary mb-3"></i>
                        <h5 class="card-title">Clean Architecture</h5>
                        <p class="card-text">Separation of concerns with Domain, Application, Infrastructure, and Presentation layers.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 text-center">
                    <div class="card-body">
                        <i class="bi bi-lightning-charge display-4 text-warning mb-3"></i>
                        <h5 class="card-title">High Performance</h5>
                        <p class="card-text">Optimized for speed with in-memory database and efficient data access patterns.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 text-center">
                    <div class="card-body">
                        <i class="bi bi-shield-check display-4 text-success mb-3"></i>
                        <h5 class="card-title">Secure & Reliable</h5>
                        <p class="card-text">Built with ASP.NET Core best practices for security and reliability.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="bg-light py-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <h3 class="mb-3">Ready to boost your productivity?</h3>
                <p class="mb-4">Join thousands of users who have streamlined their task management with TaskFlow.</p>
            </div>
            <div class="col-lg-4 text-lg-end">
                <a href="/Task" class="btn btn-primary btn-lg">
                    <i class="bi bi-rocket-takeoff me-2"></i>Start Managing Tasks
                </a>
            </div>
        </div>
    </div>
</section>
