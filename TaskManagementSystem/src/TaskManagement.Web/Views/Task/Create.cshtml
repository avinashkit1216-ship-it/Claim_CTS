@model TaskManagement.Web.ViewModels.TaskFormViewModel

@{
    ViewData["Title"] = Model.IsEditMode ? "Edit Task" : "Create Task";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-plus-circle me-2"></i>@ViewData["Title"]
                    </h4>
                </div>
                <div class="card-body">
                    <form asp-action="@(Model.IsEditMode ? "Edit" : "Create")" method="post" class="needs-validation" novalidate>
                        <div asp-validation-summary="All" class="alert alert-danger mb-3"></div>

                        @if (Model.IsEditMode)
                        {
                            <input type="hidden" asp-for="Id" />
                        }

                        <div class="mb-4">
                            <label asp-for="Title" class="form-label fw-bold">
                                <i class="bi bi-tag me-1"></i>Title *
                            </label>
                            <input type="text" asp-for="Title" class="form-control form-control-lg" placeholder="Enter task title" required />
                            <div class="form-text">Must be 3-200 characters</div>
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-bold">
                                <i class="bi bi-textarea-resize me-1"></i>Description
                            </label>
                            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Enter task description (optional)"></textarea>
                            <div class="form-text">Max 1000 characters</div>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        @if (Model.IsEditMode)
                        {
                            <div class="mb-4">
                                <div class="form-check form-switch">
                                    <input type="checkbox" asp-for="IsCompleted" class="form-check-input" />
                                    <label asp-for="IsCompleted" class="form-check-label fw-bold">
                                        <i class="bi bi-check-circle me-1"></i>Mark as Completed
                                    </label>
                                </div>
                            </div>
                        }

                        <div class="d-flex gap-3 pt-3 border-top">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-save me-2"></i>@(Model.IsEditMode ? "Update" : "Create") Task
                            </button>
                            <a href="@Url.Action("Index", "Task")" class="btn btn-outline-secondary btn-lg">
                                <i class="bi bi-arrow-left me-2"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        // Custom form validation
        (function () {
            'use strict'
            var forms = document.querySelectorAll('.needs-validation')
            Array.prototype.slice.call(forms)
                .forEach(function (form) {
                    form.addEventListener('submit', function (event) {
                        if (!form.checkValidity()) {
                            event.preventDefault()
                            event.stopPropagation()
                        }
                        form.classList.add('was-validated')
                    }, false)
                })
        })()
    </script>
}
